# secrets.yaml.example
# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is listed in .gitignore — never commit it.

tenable:
  access_key: "YOUR_TENABLE_ACCESS_KEY"
  secret_key: "YOUR_TENABLE_SECRET_KEY"

# Only needed if using CrowdStrike asset collection
crowdstrike:
  client_id: "YOUR_CROWDSTRIKE_CLIENT_ID"
  client_secret: "YOUR_CROWDSTRIKE_CLIENT_SECRET"

# Only needed if using PostgreSQL (recommended for production)
database:
  user: "tenable_trends_user"
  password: "ChangeMe123!"
